{
	"name": "@sematico/polypot",
	"version": "0.1.1",
	"description": "AI-powered translation CLI for .pot files",
	"license": "MIT",
	"author": "",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/alessandrotesoro/polypot.git"
	},
	"homepage": "https://github.com/alessandrotesoro/polypot#readme",
	"bugs": {
		"url": "https://github.com/alessandrotesoro/polypot/issues"
	},
	"bin": {
		"polypot": "bin/run.js"
	},
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"/bin",
		"/dist",
		"!/dist/.tsbuildinfo",
		"/oclif.manifest.json"
	],
	"engines": {
		"node": ">=22.13.0"
	},
	"scripts": {
		"build": "tsc",
		"test": "mocha --forbid-only \"test/**/*.test.ts\"",
		"readme": "oclif readme",
		"format": "biome format --write .",
		"check": "biome check . && npm run typecheck",
		"check:fix": "biome check --write .",
		"lint": "biome lint . && npm run typecheck",
		"lint:fix": "biome lint --write .",
		"prepack": "npm run build && oclif manifest",
		"typecheck": "tsc --noEmit"
	},
	"keywords": [
		"wordpress",
		"gettext",
		"pot",
		"po",
		"translation",
		"localization",
		"oclif"
	],
	"oclif": {
		"bin": "polypot",
		"dirname": "polypot",
		"commands": "./dist/commands",
		"topicSeparator": " ",
		"helpOptions": {
			"flagSortOrder": "none"
		}
	},
	"dependencies": {
		"@inquirer/prompts": "^8.5.2",
		"@oclif/core": "^4.11.14",
		"cli-progress": "^3.12.0",
		"dotenv": "^17.4.2",
		"gettext-parser": "^9.1.1",
		"listr2": "^10.2.2",
		"openai": "^6.45.0",
		"yaml": "^2.9.0",
		"yoctocolors": "^2.1.2",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.3",
		"@oclif/test": "^4.1.20",
		"@types/chai": "^5.2.3",
		"@types/cli-progress": "^3.11.6",
		"@types/gettext-parser": "^9.0.0",
		"@types/mocha": "^10.0.10",
		"@types/node": "^26.1.1",
		"chai": "^6.2.2",
		"mocha": "^11.7.6",
		"oclif": "^4.23.27",
		"tsx": "^4.23.0",
		"typescript": "^7.0.2"
	},
	"overrides": {
		"diff": "8.0.3",
		"serialize-javascript": "7.0.5"
	}
}
